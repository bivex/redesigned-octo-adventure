{
   libpq_gssapi_leaks
   Memcheck:Leak
   match-leak-kinds:definite,indirect
   fun:malloc
   fun:*gss_acquire_cred*
}
{
   krb5_leaks
   Memcheck:Leak
   match-leak-kinds:definite,indirect
   obj:/usr/lib/x86_64-linux-gnu/libgssapi_krb5.so*
}
{
   libpq_internal
   Memcheck:Leak
   match-leak-kinds:definite,indirect
   obj:/usr/lib/x86_64-linux-gnu/libpq.so*
}
